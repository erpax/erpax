#!/usr/bin/env sh
# pre-push — Slice FFFFFF self-healing edition (2026-05-11).
#
# Same checks as `pnpm run check`, but with auto-heal of regenerable
# artefacts BEFORE the verify gates run. Regenerable artefacts that
# are stale auto-regen + auto-commit a `chore(auto-heal): pre-push
# regen — …` commit; non-regenerable failures (lint / tsc / vitest /
# missing @standard / untranslated i18n) still fail the gate.
#
# Why: commits with --no-verify (sandbox, rebase, cherry-pick, amend)
# bypass the pre-commit auto-regen hook. Without this self-heal, devs
# would have to: (a) push, (b) see gate fail, (c) run `pnpm
# standards:write-index`, (d) commit, (e) push again. With it, the
# gate self-heals + the push goes through on the first try.
#
# Bypass: git push --no-verify
#
# @standard ISO 19011:2018 §6.4.6 audit-trail self-heal-visible-in-git-log
# @standard ISO/IEC 25010:2023 §5.5 testability + §5.7 reusability
# @audit deterministic-regeneration-of-artefacts-only

cd "$(dirname "$0")/.." || exit 1
export PATH="$PWD/node_modules/.bin:$PATH"
export NODE_OPTIONS=--no-deprecation
set -e

# ── 1. Auto-heal regenerable artefacts FIRST ─────────────────────────
# Runs unconditionally — fast (~200ms when nothing's stale; ~2s when
# regenerating). Commits the heal so the rest of the gate sees a clean
# tree. Handles: docs/STANDARDS_INDEX.md, src/payload-types.ts,
# src/app/(payload)/admin/importMap.js.
bash scripts/auto-heal-generated-artefacts.sh

# ── 2. Verify gates (must pass after auto-heal) ─────────────────────
# Cheapest gate first: malformed @standard / @rfc / @compliance banners.
bash scripts/standards-citation-index.sh --check
# Every src/standards/<id>/ + tests/standards/<id>/ file MUST cite a standard.
bash scripts/standards-citation-index.sh --required
# docs/STANDARDS_INDEX.md must be in sync with current banners.
# (Auto-healed above; this is the assert that the heal worked.)
bash scripts/standards-citation-index.sh --verify-index
# src/payload-types.ts must be in sync with the live Payload config —
# stale types let tsc pass in dev but fail in fresh checkouts.
# (Auto-healed above when pnpm is available; this is the assert.)
bash scripts/payload-verify-types.sh
# ── Speech gate (added 2026-06-03 from session learnings) ──
# Every [[link]] must resolve to a SKILL.md page — the aura whole; a dead link is an
# unanswered question (the docs build's ignoreDeadLinks twin, but cheap + matter-side).
# Dead links slipped through twice this build ([[skill]], [[links]]) because this gate
# was not enforced at push. Orphans stay advisory — gate on DEAD links only.
# Canonical scanner is src/aura/scan.mjs (matches package.json aura:scan + confirm.mjs);
# the old .claude/skills/aura/scan.mjs path does NOT resolve in the live tree. FAIL-CLOSED:
# the `|| true` is dropped so a scanner CRASH aborts under `set -e` (cannot-run = did-not-pass)
# rather than being swallowed into an empty AURA_OUT.
AURA_OUT="$(node src/aura/scan.mjs 2>/dev/null)"
case "$AURA_OUT" in
  *"gap = 0 "*) : ;;
  *) echo "✖ aura: dead [[link]](s) found (gap>0) — run: pnpm aura:scan"; exit 1 ;;
esac
# Import-convention RATCHET (the wire): a non-index/deep import lowers coverage; this fails
# the push when the live non-index count EXCEEDS the committed baseline. Fail-closed (a scan
# error exits non-zero). The convention now HOLDS because this gate holds it.
cross-env NODE_OPTIONS="--no-deprecation --import=tsx/esm" node src/convention/import/gate.mjs
# Folder-shape law — TWO independent GUARDIANS (src/law/folder): every atom is ONE
# generic lowercase word holding only its SKILL.md / index.ts / test.ts trinity
# (translations.ts / seed.ts allowed). The NAME guardian fails when name violations
# exceed NAME_BASELINE; the TRINITY guardian fails when trinity gaps exceed
# TRINITY_BASELINE. Each ratchets DOWN on its own, so a new non-one-word folder
# (e.g. trading-apis) is caught even when trinity improves. No backward-compat sum.
# Fail-closed: a scan error exits non-zero under `set -e` (cannot-run = did-not-pass).
tsx src/law/folder/index.ts --check
# Skill frontmatter YAML safety — an unquoted description with ": " breaks the docs
# YAML parse (bit access/sacred). Another step of the one horo gate (who can't dance can't join).
node scripts/check-skill-frontmatter.mjs
eslint . --quiet
pnpm run lint:src
tsc --noEmit -p tsconfig.typecheck.json
PAYLOAD_TEST_SKIP_MIGRATE=1 vitest run --config ./vitest.config.mts
