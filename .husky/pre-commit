#!/usr/bin/env sh
# pre-commit — auto-regenerate the artefacts the pre-push gate VERIFIES,
# so devs never have to remember to run them by hand. Conditional on what's
# staged so doc-only / script-only commits stay fast.
#
# Wired artefacts:
#   • src/payload-types.ts          — when any Payload collection / config / field changes
#   • src/app/(payload)/admin/importMap.js — same trigger
#   • docs/STANDARDS_INDEX.md       — when any file carrying a standards banner changes
#
# Bypass (intentional skip): git commit --no-verify
#
# @standard ISO-19011:2018 audit-trail generated-artefacts-fresh-on-commit
# @standard ISO-25010:2023 quality-model maintainability automation
cd "$(dirname "$0")/.." || exit 1
export PATH="$PWD/node_modules/.bin:$PATH"
export NODE_OPTIONS="--no-deprecation --import=./src/css/load-hook.mjs"
set -e

staged=$(git diff --cached --name-only --diff-filter=ACMR)
[ -z "$staged" ] && exit 0

# 1. Payload types + admin importmap — regen when any collection / payload-config /
#    fields file changes. The verify gate (`payload-verify-types.sh`) runs in
#    pre-push and would otherwise reject a stale `src/payload-types.ts`.
if echo "$staged" | grep -E '^src/(plugins/.*/collections/|collections/|fields/|.*payload\.config\.ts$|.*payload-config\.ts$)' | grep -vE '/(README|SKILL|LLM)\.md$|diamond\.json$' >/dev/null; then
  echo "pre-commit: collection/config change — regenerating Payload types + importmap"
  pnpm exec cross-env NODE_OPTIONS="--no-deprecation --max-old-space-size=8000 --import=./src/css/load-hook.mjs" payload generate:types >/dev/null
  pnpm exec cross-env NODE_OPTIONS="--no-deprecation --max-old-space-size=8000 --import=./src/css/load-hook.mjs" payload generate:importmap >/dev/null
  git add src/payload-types.ts src/app/'(payload)'/admin/importMap.js 2>/dev/null || true
fi

# 2. Standards citation index — regen when any file with a standards banner
#    changes. The verify gate (`standards-citation-index.sh --verify-index`)
#    runs in pre-push and would otherwise reject a stale `STANDARDS_INDEX.md`.
if echo "$staged" | grep -E '\.(ts|tsx|js|jsx|md)$' >/dev/null; then
  has_banner=0
  for f in $staged; do
    [ -f "$f" ] || continue
    if grep -lE '@(standard|rfc|compliance|accounting|audit|security)\b' "$f" >/dev/null 2>&1; then
      has_banner=1
      break
    fi
  done
  if [ "$has_banner" = 1 ]; then
    echo "pre-commit: standards-banner change — regenerating docs/STANDARDS_INDEX.md"
    bash scripts/standards-citation-index.sh --write-index >/dev/null
    git add docs/STANDARDS_INDEX.md 2>/dev/null || true
  fi
fi

# 3. Skill harmony (the finest horo ring — the earliest catch). When any SKILL.md is
#    staged, the speech gate (every [[link]] resolves; aura gap=0) and frontmatter YAML
#    safety must hold AT COMMIT, before push. The gate is horo: who cannot dance cannot
#    even commit. (Verified-safe: the corpus is clean, so this never false-fails.)
if echo "$staged" | grep -E 'SKILL\.md$' >/dev/null; then
  # Canonical scanner is src/aura/scan.mjs (matches package.json aura:scan + confirm.mjs);
  # the old .claude/skills/aura/scan.mjs path does NOT resolve. FAIL-CLOSED: drop `|| true`
  # so a scanner CRASH aborts under `set -e` rather than masking as an empty AURA_OUT.
  AURA_OUT="$(node src/aura/scan.mjs 2>/dev/null)"
  case "$AURA_OUT" in
    *"gap = 0 "*) : ;;
    *) echo "✖ aura: dead [[link]](s) found (gap>0) — run: pnpm aura:scan"; exit 1 ;;
  esac
  node scripts/check-skill-frontmatter.mjs
fi
