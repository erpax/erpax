/**
 * Depreciation Hook — calculates and posts PP&E depreciation.
 *
 * Methods: straight-line, declining balance, units-of-activity.
 *
 * @accounting IFRS IAS-16 property-plant-and-equipment
 * @accounting IFRS IAS-36 impairment-of-assets
 * @accounting US-GAAP ASC-360 property-plant-and-equipment
 * @standard ISO-8601-1:2019 date-time depreciation-period
 * @audit ISO-19011:2018 audit-trail
 * @compliance SOX §404 internal-controls
 * @see docs/STANDARDS.md §4.2
 */

import type { CollectionAfterChangeHook } from 'payload'
export const depreciationHook: CollectionAfterChangeHook = async ({
  doc,
  req,
  operation,
}) => {
  if (!doc || operation !== 'create') return doc;

  try {
    const depreciationService = req.payload.services?.depreciation;
    const hostId = undefined || doc.tenant;

    if (depreciationService) {
      const assetData = {
        id: doc.id,
        assetNumber: doc.assetNumber,
        description: doc.description,
        assetCategory: doc.assetCategory,
        acquisitionDate: doc.acquisitionDate,
        assetCost: doc.assetCost,
        residualValue: doc.residualValue,
        usefulLifeYears: doc.usefulLifeYears,
        depreciationMethod: doc.depreciationMethod,
        depreciationStartDate: doc.depreciationStartDate,
        currency: doc.currency || 'EUR',
      };

      await depreciationService.calculateDepreciation(hostId, assetData);
      req.payload.logger.info(`✓ Depreciation schedule created for asset ${doc.assetNumber}`);
    }
  } catch (error) {
    req.payload.logger.error({ err: error }, `✗ Error calculating depreciation:`);
  }

  return doc;
};
