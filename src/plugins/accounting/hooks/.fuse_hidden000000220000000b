/**
 * Bill GL Posting Hook — auto-creates GL entry on bill change.
 *
 * Debit expense account (per category), Credit 2100 (AP).
 *
 * @accounting IFRS IAS-37 provisions-contingent-liabilities
 * @accounting US-GAAP ASC-405 liabilities
 * @accounting US-GAAP ASC-705 cost-of-sales-and-services
 * @audit ISO-19011:2018 audit-trail double-entry-posting
 * @compliance SOX §404 internal-controls
 * @security ISO-27002 §5.4 segregation-of-duties
 * @see docs/STANDARDS.md §4.2
 */

import type { CollectionAfterChangeHook } from 'payload'
export const billAccountingHook: CollectionAfterChangeHook = async ({
  doc,
  req,
  operation,
}) => {
  if (!doc || (operation !== 'create' && operation !== 'update')) return doc;

  try {
    const glPostingService = req.payload.services?.glPosting;
    const hostId = req.payload.requestContext?.hostId || doc.hostId;

    if (glPostingService) {
      const billData = {
        id: doc.id,
        billNumber: doc.billNumber,
        billDate: doc.billDate,
        vendorId: doc.vendorId,
        amount: doc.totalAmount,
        currency: doc.currency || 'EUR',
        items: doc.lineItems || [],
        description: `Bill ${doc.billNumber}`,
      };

      await glPostingService.postBill(hostId, billData);
      console.log(`✓ GL posting created for bill ${doc.billNumber}`);
    }
  } catch (error) {
    console.error(`✗ Error creating GL posting for bill:`, error);
  }

  return doc;
};
