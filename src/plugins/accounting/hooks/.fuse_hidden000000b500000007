/**
 * Invoice GL Posting Hook — auto-creates GL entry on invoice change.
 *
 * Debit 1200 (AR), Credit 4000 (Revenue). If inventory: Debit 5000 (COGS),
 * Credit 1300 (Inventory).
 *
 * @accounting IFRS IFRS-15 revenue-from-contracts-with-customers
 * @accounting US-GAAP ASC-606 revenue-from-contracts-with-customers
 * @accounting US-GAAP ASC-310 receivables
 * @accounting US-GAAP ASC-330 inventory cogs-recognition
 * @audit ISO-19011:2018 audit-trail double-entry-posting
 * @compliance SOX §404 internal-controls
 * @see docs/STANDARDS.md §4.2
 */

import { CollectionAfterChangeHook } from 'payload/types';

export const invoiceAccountingHook: CollectionAfterChangeHook = async ({
  doc,
  req,
  operation,
}) => {
  if (!doc || (operation !== 'create' && operation !== 'update')) return doc;

  try {
    const glPostingService = req.payload.services?.glPosting;
    const hostId = req.payload.requestContext?.hostId || doc.hostId;

    if (glPostingService) {
      const invoiceData = {
        id: doc.id,
        invoiceNumber: doc.invoiceNumber,
        invoiceDate: doc.invoiceDate,
        customerId: doc.customerId,
        amount: doc.totalAmount,
        currency: doc.currency || 'EUR',
        items: doc.lineItems || [],
        description: `Invoice ${doc.invoiceNumber}`,
      };

      await glPostingService.postInvoice(hostId, invoiceData);
      console.log(`✓ GL posting created for invoice ${doc.invoiceNumber}`);
    }
  } catch (error) {
    console.error(`✗ Error creating GL posting for invoice:`, error);
  }

  return doc;
};
