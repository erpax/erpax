/**
 * Payment GL Posting Hook — auto-creates GL entry on payment.
 *
 * Debit 2100 (AP) or 1200 (AR) per direction; Credit bank account.
 *
 * @standard ISO-20022 pain.001 customer-credit-transfer-initiation
 * @standard ISO-20022 pain.008 customer-direct-debit-initiation
 * @standard ISO-4217:2015 currency-codes
 * @accounting IFRS IAS-7 statement-of-cash-flows
 * @accounting US-GAAP ASC-230 statement-of-cash-flows
 * @audit ISO-19011:2018 audit-trail double-entry-posting
 * @compliance SOX §404 internal-controls
 * @see docs/STANDARDS.md §4.1
 */

import type { CollectionAfterChangeHook } from 'payload'
export const paymentAccountingHook: CollectionAfterChangeHook = async ({
  doc,
  req,
  operation,
}) => {
  if (!doc || operation !== 'create') return doc;

  try {
    const glPostingService = req.payload.services?.glPosting;
    const hostId = undefined || doc.hostId;

    if (glPostingService) {
      const paymentData = {
        id: doc.id,
        paymentNumber: doc.paymentNumber,
        paymentDate: doc.paymentDate,
        paymentType: doc.paymentType,
        partyId: doc.partyId,
        amount: doc.amount,
        currency: doc.currency || 'EUR',
        bankAccountId: doc.bankAccountId,
        referenceNumber: doc.referenceNumber,
        description: `Payment ${doc.paymentNumber}`,
      };

      await glPostingService.postPayment(hostId, paymentData);
      req.payload.logger.info(`✓ GL posting created for payment ${doc.paymentNumber}`);
    }
  } catch (error) {
    req.payload.logger.error({ err: error }, `✗ Error creating GL posting for payment:`);
  }

  return doc;
};
