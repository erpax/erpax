/**
 * Level 3: OPTIMAL E2E Test Seeds for Export Plugin
 * Complete business cycles, real-time exports, streaming data
 * Setup time: 5-15 seconds
 * Real-time exports, 30-day history, 10+ schedules
 * Multi-destination delivery, error handling, compliance, performance
 */

import type { Payload } from 'payload';
import { TestSeedFactory, type SeedResult } from '../../../../src/testing';

/**
 * Real-time Export Seed - Streaming and continuous updates
 */
export class OptimalRealTimeExportSeed extends TestSeedFactory {
  private createdIds: Set<string> = new Set();

  async seed(): Promise<SeedResult> {
    this.context = this.createContext('e2e');

    try {
      if (this.hooks.beforeSeed) {
        await this.hooks.beforeSeed(this.context);
      }

      // Real-time Stream 1: Live Transaction Feed
      const txnStream = await this.createDocument('realtime-exports', {
        name: 'Live Transaction Feed',
        code: 'LIVE_TXN_STREAM',
        sourceType: 'transaction',
        format: 'json-stream',
        streamingProtocol: 'websocket',
        endpoint: 'wss://api.finance.local/stream/transactions',
        batchSize: 10,
        batchTimeout: 1000,
        compressionEnabled: true,
        compressionType: 'gzip',
        encryptionEnabled: true,
        encryptionAlgorithm: 'AES-256-GCM',
        subscribers: [
          { id: 'subscriber-1', endpoint: 'wss://analytics.local/import' },
          { id: 'subscriber-2', endpoint: 'wss://audit.local/import' },
        ],
        status: 'active',
      });
      this.createdIds.add(txnStream.id);

      // Real-time Stream 2: GL Balance Updates
      const balanceStream = await this.createDocument('realtime-exports', {
        name: 'GL Balance Update Stream',
        code: 'BALANCE_UPDATE_STREAM',
        sourceType: 'gl-account-balance',
        format: 'json-stream',
        streamingProtocol: 'mqtt',
        endpoint: 'mqtt://broker.finance.local:1883/gl/balances',
        qos: 2,
        retainMessages: true,
        batchSize: 50,
        batchTimeout: 5000,
        compressionEnabled: true,
        status: 'active',
      });
      this.createdIds.add(balanceStream.id);

      // Real-time Stream 3: Event-Driven Journal Entries
      const journalStream = await this.createDocument('realtime-exports', {
        name: 'Event-Driven Journal Entry Stream',
        code: 'JOURNAL_EVENT_STREAM',
        sourceType: 'journal-entry',
        format: 'avro-stream',
        streamingProtocol: 'kafka',
        endpoint: 'kafka://broker.finance.local:9092/journal-entries',
        topic: 'finance.journal-entries',
        partitions: 3,
        replicationFactor: 2,
        compressionType: 'snappy',
        schemaRegistry: 'https://schema.finance.local:8081',
        status: 'active',
      });
      this.createdIds.add(journalStream.id);

      // Real-time Stream 4: Continuous Reconciliation
      const reconStream = await this.createDocument('realtime-exports', {
        name: 'Continuous Reconciliation Stream',
        code: 'RECON_STREAM',
        sourceType: 'reconciliation-item',
        format: 'protobuf-stream',
        streamingProtocol: 'grpc',
        endpoint: 'grpc://reconciliation.finance.local:50051',
        deadLetterQueueEnabled: true,
        dlqEndpoint: 'grpc://dlq.finance.local:50051',
        maxRetries: 5,
        status: 'active',
      });
      this.createdIds.add(reconStream.id);

      // Real-time Stream 5: Dashboard Data Feed
      const dashboardStream = await this.createDocument('realtime-exports', {
        name: 'Dashboard Real-Time Feed',
        code: 'DASHBOARD_FEED',
        sourceType: 'dashboard-metric',
        format: 'json-stream',
        streamingProtocol: 'websocket',
        endpoint: 'wss://dashboard.finance.local/stream/metrics',
        cachingEnabled: true,
        cacheTTL: 30,
        aggregationWindow: 10000,
        status: 'active',
      });
      this.createdIds.add(dashboardStream.id);

      // Track all created IDs
      this.createdIds.forEach(id => this.trackCreatedId('realtime-exports', id));

      if (this.hooks.afterSeed) {
        const stats = this.getStats();
        const result: SeedResult = {
          success: true,
          ...stats,
        };
        await this.hooks.afterSeed(this.context, result);
      }

      return {
        success: true,
        ...this.getStats(),
      };
    } catch (error) {
      return {
        success: false,
        seedLevel: 'e2e',
        totalTime: Date.now() - this.context!.startTime,
        itemsCreated: 0,
        collections: {},
        error: error instanceof Error ? error : new Error(String(error)),
      };
    }
  }

  private async createDocument(collection: string, data: Record<string, any>) {
    await this.validateData(collection, data);
    return await this.payload.create({
      collection,
      data,
    });
  }

  protected async validateData(collection: string, data: Record<string, any>): Promise<void> {
    if (collection === 'realtime-exports') {
      await super.validateData(collection, data);
    }
  }

  private getStats() {
    const stats: any = {
      seedLevel: 'e2e',
      totalTime: Date.now() - this.context!.startTime,
      itemsCreated: this.createdIds.size,
      collections: {
        'realtime-exports': this.createdIds.size,
      },
    };
    return stats;
  }
}

/**
 * Scheduled Export Seed - 30-day history with 10+ schedules
 */
export class OptimalScheduledExportSeed extends TestSeedFactory {
  private createdIds: Set<string> = new Set();

  async seed(): Promise<SeedResult> {
    this.context = this.createContext('e2e');

    try {
      if (this.hooks.beforeSeed) {
        await this.hooks.beforeSeed(this.context);
      }

      // Generate 10 schedules with 30 days of execution history
      const now = new Date();
      const scheduleConfigs = [
        { name: 'Daily Statements', frequency: 'daily', time: '08:00' },
        { name: 'Weekly Reports', frequency: 'weekly', day: 'Monday', time: '09:00' },
        { name: 'Monthly Close', frequency: 'monthly', dayOfMonth: 1, time: '10:00' },
        { name: 'Quarterly Reviews', frequency: 'quarterly', months: [3, 6, 9, 12], time: '11:00' },
        { name: 'Year-End Audit', frequency: 'annually', month: 'December', time: '17:00' },
        { name: 'Hourly Snapshots', frequency: 'hourly', minute: 0 },
        { name: 'Real-time Sync', frequency: 'continuous', batchSize: 100 },
        { name: 'End-of-Day', frequency: 'daily', time: '23:59' },
        { name: 'Week Start Report', frequency: 'weekly', day: 'Monday', time: '06:00' },
        { name: 'Mid-Month Review', frequency: 'monthly', dayOfMonth: 15, time: '14:00' },
      ];

      for (const config of scheduleConfigs) {
        const schedule = await this.createDocument('scheduled-exports', {
          name: config.name,
          code: config.name.toUpperCase().replace(/ /g, '_'),
          templateId: 'template-1',
          ...config,
          timezone: 'America/New_York',
          retryPolicy: { maxRetries: 3, backoffMultiplier: 2 },
          destinations: [
            { type: 'email', recipients: ['finance@company.com'] },
            { type: 'cloud-storage', bucket: 'exports-bucket' },
          ],
          dataValidation: { enabled: true, failOnError: false },
          notificationPolicy: { notifyOnSuccess: true, notifyOnFailure: true },
          status: 'active',
        });
        this.createdIds.add(schedule.id);

        // Create 30 days of execution history for each schedule
        for (let dayOffset = 0; dayOffset < 30; dayOffset++) {
          const executionDate = new Date(now.getTime() - dayOffset * 86400000);
          const dayOfWeek = executionDate.getDay();
          const dayOfMonth = executionDate.getDate();
          
          // Check if this day should have an execution based on frequency
          let shouldExecute = false;
          if (config.frequency === 'daily') shouldExecute = true;
          else if (config.frequency === 'weekly' && (config.day === 'Monday' ? dayOfWeek === 1 : dayOfWeek === 1)) shouldExecute = true;
          else if (config.frequency === 'monthly' && dayOfMonth === config.dayOfMonth) shouldExecute = true;
          else if (config.frequency === 'quarterly') shouldExecute = true; // Simplified
          else if (config.frequency === 'hourly') shouldExecute = true;
          else if (config.frequency === 'continuous') shouldExecute = true;
          else if (config.frequency === 'annually') shouldExecute = true;

          if (shouldExecute) {
            const execution = await this.createDocument('scheduled-export-executions', {
              scheduleId: schedule.id,
              executionDate: executionDate.toISOString(),
              status: dayOffset % 7 === 0 ? 'failed' : dayOffset % 5 === 0 ? 'partial' : 'success',
              recordsProcessed: 1000 + dayOffset * 10,
              recordsFailed: dayOffset % 7 === 0 ? 10 : dayOffset % 5 === 0 ? 2 : 0,
              fileSizeBytes: 500000 + dayOffset * 5000,
              duration: Math.floor(Math.random() * 30000) + 5000,
              nextExecutionTime: new Date(executionDate.getTime() + 86400000).toISOString(),
            });
            this.createdIds.add(execution.id);
          }
        }
      }

      // Track all created IDs
      this.createdIds.forEach(id => this.trackCreatedId('scheduled-exports', id));
      this.createdIds.forEach(id => this.trackCreatedId('scheduled-export-executions', id));

      if (this.hooks.afterSeed) {
        const stats = this.getStats();
        const result: SeedResult = {
          success: true,
          ...stats,
        };
        await this.hooks.afterSeed(this.context, result);
      }

      return {
        success: true,
        ...this.getStats(),
      };
    } catch (error) {
      return {
        success: false,
        seedLevel: 'e2e',
        totalTime: Date.now() - this.context!.startTime,
        itemsCreated: 0,
        collections: {},
        error: error instanceof Error ? error : new Error(String(error)),
      };
    }
  }

  private async createDocument(collection: string, data: Record<string, any>) {
    await this.validateData(collection, data);
    return await this.payload.create({
      collection,
      data,
    });
  }

  protected async validateData(collection: string, data: Record<string, any>): Promise<void> {
    if (collection === 'scheduled-exports' || collection === 'scheduled-export-executions') {
      await super.validateData(collection, data);
    }
  }

  private getStats() {
    const stats: any = {
      seedLevel: 'e2e',
      totalTime: Date.now() - this.context!.startTime,
      itemsCreated: this.createdIds.size,
      collections: {
        'scheduled-exports': 10,
        'scheduled-export-executions': this.createdIds.size - 10,
      },
    };
    return stats;
  }
}

/**
 * Multi-Destination Seed - Email, FTP, Cloud, API endpoints
 */
export class OptimalMultiDestinationSeed extends TestSeedFactory {
  private createdIds: Set<string> = new Set();

  async seed(): Promise<SeedResult> {
    this.context = this.createContext('e2e');

    try {
      if (this.hooks.beforeSeed) {
        await this.hooks.beforeSeed(this.context);
      }

      // Destination 1: Email Distribution
      const emailDest = await this.createDocument('export-destinations', {
        name: 'Finance Team Email',
        code: 'EMAIL_FINANCE_TEAM',
        type: 'email',
        protocol: 'smtp',
        host: 'smtp.company.com',
        port: 587,
        useTLS: true,
        fromAddress: 'exports@company.com',
        recipients: [
          { email: 'finance-lead@company.com', format: 'pdf' },
          { email: 'accounting@company.com', format: 'excel' },
          { email: 'audit@company.com', format: 'pdf' },
        ],
        cc: ['cfo@company.com'],
        bcc: ['archive@company.com'],
        subjectTemplate: 'Financial Export - {exportDate}',
        bodyTemplate: 'Please find attached the {exportName} for {period}',
        attachmentPolicy: 'inline',
        retryPolicy: { maxRetries: 5, retryDelay: 300 },
        status: 'active',
      });
      this.createdIds.add(emailDest.id);

      // Destination 2: FTP Server
      const ftpDest = await this.createDocument('export-destinations', {
        name: 'Partner FTP Server',
        code: 'FTP_PARTNER_SECURE',
        type: 'ftp',
        protocol: 'sftp',
        host: 'ftp.partner.com',
        port: 22,
        username: 'export_user',
        password: 'encrypted_password',
        basePath: '/incoming/exports',
        fileNamingPattern: '{exportName}_{timestamp}.{format}',
        createDirectoryStructure: true,
        filePermissions: '0644',
        deleteAfterTransfer: false,
        verifyChecksum: true,
        retryPolicy: { maxRetries: 3, retryDelay: 600 },
        status: 'active',
      });
      this.createdIds.add(ftpDest.id);

      // Destination 3: AWS S3 Cloud Storage
      const s3Dest = await this.createDocument('export-destinations', {
        name: 'AWS S3 Archive',
        code: 'S3_ARCHIVE_BUCKET',
        type: 'cloud-storage',
        provider: 'aws-s3',
        region: 'us-east-1',
        bucket: 'finance-exports-archive',
        accessKey: 'encrypted_access_key',
        secretKey: 'encrypted_secret_key',
        basePath: 'exports/{year}/{month}',
        serverSideEncryption: 'AES256',
        storageClass: 'INTELLIGENT_TIERING',
        versioning: true,
        lifecycle: {
          archiveAfterDays: 90,
          deleteAfterDays: 2555,
        },
        retryPolicy: { maxRetries: 3, retryDelay: 1000 },
        status: 'active',
      });
      this.createdIds.add(s3Dest.id);

      // Destination 4: REST API Webhook
      const apiDest = await this.createDocument('export-destinations', {
        name: 'Analytics API Webhook',
        code: 'API_ANALYTICS_WEBHOOK',
        type: 'api',
        method: 'POST',
        endpoint: 'https://analytics.company.com/v1/exports/import',
        authType: 'bearer-token',
        token: 'encrypted_bearer_token',
        headers: {
          'X-API-Key': 'api-key-123',
          'X-Source': 'erpax-export',
        },
        payload: {
          includeMetadata: true,
          formatData: 'structured',
        },
        timeout: 30000,
        retryPolicy: { maxRetries: 5, retryDelay: 1000 },
        status: 'active',
      });
      this.createdIds.add(apiDest.id);

      // Destination 5: Kafka Streaming Topic
      const kafkaDest = await this.createDocument('export-destinations', {
        name: 'Kafka Message Stream',
        code: 'KAFKA_STREAM_TOPIC',
        type: 'streaming',
        provider: 'kafka',
        brokers: ['broker1.kafka.local:9092', 'broker2.kafka.local:9092'],
        topic: 'finance-exports',
        partition: 0,
        compressionType: 'snappy',
        requiredAcks: 'all',
        timeout: 30000,
        schemaRegistry: 'https://schema.kafka.local:8081',
        status: 'active',
      });
      this.createdIds.add(kafkaDest.id);

      // Destination 6: Azure Blob Storage
      const azureDest = await this.createDocument('export-destinations', {
        name: 'Azure Blob Storage',
        code: 'AZURE_BLOB_STORAGE',
        type: 'cloud-storage',
        provider: 'azure-blob',
        accountName: 'storageaccount',
        accountKey: 'encrypted_account_key',
        containerName: 'exports',
        basePath: 'financial/{year}/{month}',
        tier: 'Hot',
        redundancy: 'GRS',
        retryPolicy: { maxRetries: 3, retryDelay: 1000 },
        status: 'active',
      });
      this.createdIds.add(azureDest.id);

      // Destination 7: Google Cloud Storage
      const gcsDest = await this.createDocument('export-destinations', {
        name: 'Google Cloud Storage',
        code: 'GCS_BUCKET',
        type: 'cloud-storage',
        provider: 'google-cloud-storage',
        projectId: 'finance-project',
        bucket: 'finance-exports',
        keyFile: 'encrypted_service_account_key',
        basePath: 'exports/{year}/{month}',
        storageClass: 'STANDARD',
        uniformBucketLevelAccess: true,
        retryPolicy: { maxRetries: 3, retryDelay: 1000 },
        status: 'active',
      });
      this.createdIds.add(gcsDest.id);

      // Destination 8: Webhook with Backoff
      const webhookDest = await this.createDocument('export-destinations', {
        name: 'Internal Webhook',
        code: 'INTERNAL_WEBHOOK',
        type: 'webhook',
        method: 'POST',
        endpoint: 'https://internal-api.company.local/exports/receive',
        authType: 'api-key',
        apiKey: 'encrypted_api_key',
        timeout: 15000,
        retryPolicy: {
          maxRetries: 5,
          initialDelay: 1000,
          maxDelay: 30000,
          backoffMultiplier: 2,
        },
        status: 'active',
      });
      this.createdIds.add(webhookDest.id);

      // Track all created IDs
      this.createdIds.forEach(id => this.trackCreatedId('export-destinations', id));

      if (this.hooks.afterSeed) {
        const stats = this.getStats();
        const result: SeedResult = {
          success: true,
          ...stats,
        };
        await this.hooks.afterSeed(this.context, result);
      }

      return {
        success: true,
        ...this.getStats(),
      };
    } catch (error) {
      return {
        success: false,
        seedLevel: 'e2e',
        totalTime: Date.now() - this.context!.startTime,
        itemsCreated: 0,
        collections: {},
        error: error instanceof Error ? error : new Error(String(error)),
      };
    }
  }

  private async createDocument(collection: string, data: Record<string, any>) {
    await this.validateData(collection, data);
    return await this.payload.create({
      collection,
      data,
    });
  }

  protected async validateData(collection: string, data: Record<string, any>): Promise<void> {
    if (collection === 'export-destinations') {
      await super.validateData(collection, data);
    }
  }

  private getStats() {
    const stats: any = {
      seedLevel: 'e2e',
      totalTime: Date.now() - this.context!.startTime,
      itemsCreated: this.createdIds.size,
      collections: {
        'export-destinations': this.createdIds.size,
      },
    };
    return stats;
  }
}

/**
 * Error Handling Seed - Failed, retried, and recovered exports
 */
export class OptimalErrorHandlingSeed extends TestSeedFactory {
  private createdIds: Set<string> = new Set();

  async seed(): Promise<SeedResult> {
    this.context = this.createContext('e2e');

    try {
      if (this.hooks.beforeSeed) {
        await this.hooks.beforeSeed(this.context);
      }

      // Error Scenario 1: Failed Export - Timeout
      const failedTimeout = await this.createDocument('error-logs', {
        exportId: 'export-failed-001',
        errorCode: 'EXPORT_TIMEOUT',
        severity: 'high',
        message: 'Export operation exceeded timeout of 300 seconds',
        timestamp: new Date().toISOString(),
        details: {
          recordsProcessed: 5000,
          recordsTotal: 10000,
          timeElapsed: 305000,
        },
        retryAttempts: [
          { attempt: 1, timestamp: new Date().toISOString(), status: 'failed' },
          { attempt: 2, timestamp: new Date(Date.now() + 60000).toISOString(), status: 'failed' },
          { attempt: 3, timestamp: new Date(Date.now() + 120000).toISOString(), status: 'success' },
        ],
        resolution: 'Increased timeout to 600s, export succeeded on third attempt',
        resolvedAt: new Date(Date.now() + 180000).toISOString(),
        status: 'resolved',
      });
      this.createdIds.add(failedTimeout.id);

      // Error Scenario 2: Failed Export - Invalid Data
      const failedValidation = await this.createDocument('error-logs', {
        exportId: 'export-failed-002',
        errorCode: 'DATA_VALIDATION_ERROR',
        severity: 'medium',
        message: 'Data validation failed: Invalid account type in row 523',
        timestamp: new Date().toISOString(),
        details: {
          row: 523,
          field: 'accountType',
          value: 'INVALID_TYPE',
          expectedValues: ['asset', 'liability', 'equity', 'revenue', 'expense'],
        },
        retryAttempts: [
          { attempt: 1, timestamp: new Date().toISOString(), status: 'failed' },
        ],
        resolution: 'Fixed account master data, re-exported successfully',
        resolvedAt: new Date(Date.now() + 3600000).toISOString(),
        status: 'resolved',
      });
      this.createdIds.add(failedValidation.id);

      // Error Scenario 3: Failed Export - Connection Error
      const failedConnection = await this.createDocument('error-logs', {
        exportId: 'export-failed-003',
        errorCode: 'DESTINATION_UNAVAILABLE',
        severity: 'high',
        message: 'Cannot connect to FTP server: Connection timeout',
        timestamp: new Date().toISOString(),
        details: {
          destination: 'ftp.partner.com',
          port: 22,
          protocol: 'sftp',
        },
        retryAttempts: [
          { attempt: 1, timestamp: new Date().toISOString(), status: 'failed' },
          { attempt: 2, timestamp: new Date(Date.now() + 300000).toISOString(), status: 'failed' },
          { attempt: 3, timestamp: new Date(Date.now() + 600000).toISOString(), status: 'failed' },
          { attempt: 4, timestamp: new Date(Date.now() + 1200000).toISOString(), status: 'success' },
        ],
        resolution: 'Partner server was down for maintenance, came back online',
        resolvedAt: new Date(Date.now() + 1260000).toISOString(),
        status: 'resolved',
      });
      this.createdIds.add(failedConnection.id);

      // Error Scenario 4: Partial Failure
      const partialFailure = await this.createDocument('error-logs', {
        exportId: 'export-partial-001',
        errorCode: 'PARTIAL_EXPORT_FAILURE',
        severity: 'medium',
        message: '8 of 10 destination deliveries failed',
        timestamp: new Date().toISOString(),
        details: {
          destinations: {
            successful: 2,
            failed: 8,
            failedDestinations: [
              { name: 'Email Distribution', reason: 'SMTP authentication failed' },
              { name: 'FTP Server', reason: 'Directory not accessible' },
            ],
          },
        },
        retryAttempts: [
          { attempt: 1, timestamp: new Date().toISOString(), status: 'partial' },
          { attempt: 2, timestamp: new Date(Date.now() + 300000).toISOString(), status: 'success' },
        ],
        resolution: 'Updated credentials and folder permissions',
        resolvedAt: new Date(Date.now() + 360000).toISOString(),
        status: 'resolved',
      });
      this.createdIds.add(partialFailure.id);

      // Error Scenario 5: Data Corruption
      const dataCorruption = await this.createDocument('error-logs', {
        exportId: 'export-failed-004',
        errorCode: 'DATA_CORRUPTION_DETECTED',
        severity: 'critical',
        message: 'Generated file checksum validation failed',
        timestamp: new Date().toISOString(),
        details: {
          expectedChecksum: 'a1b2c3d4e5f6',
          actualChecksum: 'x1y2z3a4b5c6',
          fileSize: 524288000,
        },
        retryAttempts: [
          { attempt: 1, timestamp: new Date().toISOString(), status: 'failed' },
          { attempt: 2, timestamp: new Date(Date.now() + 300000).toISOString(), status: 'success' },
        ],
        resolution: 'Regenerated file, passed checksum validation on retry',
        resolvedAt: new Date(Date.now() + 360000).toISOString(),
        status: 'resolved',
      });
      this.createdIds.add(dataCorruption.id);

      // Track all created IDs
      this.createdIds.forEach(id => this.trackCreatedId('error-logs', id));

      if (this.hooks.afterSeed) {
        const stats = this.getStats();
        const result: SeedResult = {
          success: true,
          ...stats,
        };
        await this.hooks.afterSeed(this.context, result);
      }

      return {
        success: true,
        ...this.getStats(),
      };
    } catch (error) {
      return {
        success: false,
        seedLevel: 'e2e',
        totalTime: Date.now() - this.context!.startTime,
        itemsCreated: 0,
        collections: {},
        error: error instanceof Error ? error : new Error(String(error)),
      };
    }
  }

  private async createDocument(collection: string, data: Record<string, any>) {
    await this.validateData(collection, data);
    return await this.payload.create({
      collection,
      data,
    });
  }

  protected async validateData(collection: string, data: Record<string, any>): Promise<void> {
    if (collection === 'error-logs') {
      await super.validateData(collection, data);
    }
  }

  private getStats() {
    const stats: any = {
      seedLevel: 'e2e',
      totalTime: Date.now() - this.context!.startTime,
      itemsCreated: this.createdIds.size,
      collections: {
        'error-logs': this.createdIds.size,
      },
    };
    return stats;
  }
}

/**
 * Compliance Export Seed - PII masking, encryption, audit trails
 */
export class OptimalComplianceExportSeed extends TestSeedFactory {
  private createdIds: Set<string> = new Set();

  async seed(): Promise<SeedResult> {
    this.context = this.createContext('e2e');

    try {
      if (this.hooks.beforeSeed) {
        await this.hooks.beforeSeed(this.context);
      }

      // Compliance Policy 1: PII Masking Policy
      const piiMaskingPolicy = await this.createDocument('compliance-policies', {
        name: 'Standard PII Masking',
        code: 'PII_MASKING_STANDARD',
        type: 'pii-masking',
        rules: [
          { dataType: 'ssn', maskingPattern: 'XXX-XX-{last4}', scope: 'all-exports' },
          { dataType: 'email', maskingPattern: '{first}***@{domain}', scope: 'non-internal' },
          { dataType: 'phone', maskingPattern: '({areacode}) ***-****', scope: 'all-exports' },
          { dataType: 'full-name', maskingPattern: '{first} {last[0]}.', scope: 'external' },
        ],
        enforcementLevel: 'strict',
        auditLog: true,
        status: 'active',
      });
      this.createdIds.add(piiMaskingPolicy.id);

      // Compliance Policy 2: Encryption Policy
      const encryptionPolicy = await this.createDocument('compliance-policies', {
        name: 'Standard Data Encryption',
        code: 'ENCRYPTION_STANDARD',
        type: 'encryption',
        rules: [
          { scope: 'at-rest', algorithm: 'AES-256-GCM', keyRotation: 90 },
          { scope: 'in-transit', protocol: 'TLS1.3', minKeyLength: 256 },
          { scope: 'in-archive', algorithm: 'AES-256', passwordRequired: true },
        ],
        keyManagement: 'hsm',
        complianceFramework: 'HIPAA',
        status: 'active',
      });
      this.createdIds.add(encryptionPolicy.id);

      // Compliance Policy 3: Audit Trail Policy
      const auditPolicy = await this.createDocument('compliance-policies', {
        name: 'Comprehensive Audit Trail',
        code: 'AUDIT_COMPREHENSIVE',
        type: 'audit-trail',
        rules: [
          { action: 'export-created', captureFields: ['user', 'timestamp', 'templateId', 'dataRange'] },
          { action: 'export-executed', captureFields: ['user', 'timestamp', 'recordCount', 'status'] },
          { action: 'data-accessed', captureFields: ['user', 'timestamp', 'dataType', 'records'] },
          { action: 'export-delivered', captureFields: ['user', 'timestamp', 'destination', 'status'] },
          { action: 'compliance-check', captureFields: ['user', 'timestamp', 'violations', 'resolution'] },
        ],
        retention: 2555,
        immutable: true,
        status: 'active',
      });
      this.createdIds.add(auditPolicy.id);

      // Compliance Policy 4: Data Retention Policy
      const retentionPolicy = await this.createDocument('compliance-policies', {
        name: 'Financial Data Retention',
        code: 'RETENTION_FINANCIAL',
        type: 'data-retention',
        rules: [
          { dataType: 'transaction', retention: 2555, archiveAfter: 365 },
          { dataType: 'journal-entry', retention: 2555, archiveAfter: 365 },
          { dataType: 'gl-balance', retention: 2555, archiveAfter: 180 },
          { dataType: 'export-report', retention: 1825, archiveAfter: 365 },
          { dataType: 'audit-log', retention: 2555, archiveAfter: 730 },
        ],
        disposalMethod: 'cryptographic-erasure',
        status: 'active',
      });
      this.createdIds.add(retentionPolicy.id);

      // Compliance Policy 5: Access Control Policy
      const accessPolicy = await this.createDocument('compliance-policies', {
        name: 'Role-Based Access Control',
        code: 'RBAC_STANDARD',
        type: 'access-control',
        rules: [
          { role: 'finance-manager', permissions: ['create', 'read', 'execute', 'approve'] },
          { role: 'auditor', permissions: ['read', 'export', 'view-audit-trail'] },
          { role: 'controller', permissions: ['create', 'read', 'execute', 'approve', 'modify'] },
          { role: 'readonly-user', permissions: ['read'] },
        ],
        mfaRequired: true,
        ipRestrictions: true,
        sessionTimeout: 3600,
        status: 'active',
      });
      this.createdIds.add(accessPolicy.id);

      // Audit Record 1: Compliance Verification
      const complianceAudit = await this.createDocument('compliance-audit-records', {
        exportId: 'export-compliance-001',
        auditDate: new Date().toISOString(),
        policyChecked: [piiMaskingPolicy.id, encryptionPolicy.id, auditPolicy.id],
        violations: [],
        complianceScore: 100,
        certifications: ['SOX', 'HIPAA', 'GDPR'],
        signedByRole: 'compliance-officer',
        signedAt: new Date().toISOString(),
        status: 'compliant',
      });
      this.createdIds.add(complianceAudit.id);

      // Track all created IDs
      this.createdIds.forEach(id => this.trackCreatedId('compliance-policies', id));
      this.createdIds.forEach(id => this.trackCreatedId('compliance-audit-records', id));

      if (this.hooks.afterSeed) {
        const stats = this.getStats();
        const result: SeedResult = {
          success: true,
          ...stats,
        };
        await this.hooks.afterSeed(this.context, result);
      }

      return {
        success: true,
        ...this.getStats(),
      };
    } catch (error) {
      return {
        success: false,
        seedLevel: 'e2e',
        totalTime: Date.now() - this.context!.startTime,
        itemsCreated: 0,
        collections: {},
        error: error instanceof Error ? error : new Error(String(error)),
      };
    }
  }

  private async createDocument(collection: string, data: Record<string, any>) {
    await this.validateData(collection, data);
    return await this.payload.create({
      collection,
      data,
    });
  }

  protected async validateData(collection: string, data: Record<string, any>): Promise<void> {
    if (collection === 'compliance-policies' || collection === 'compliance-audit-records') {
      await super.validateData(collection, data);
    }
  }

  private getStats() {
    const stats: any = {
      seedLevel: 'e2e',
      totalTime: Date.now() - this.context!.startTime,
      itemsCreated: this.createdIds.size,
      collections: {
        'compliance-policies': 5,
        'compliance-audit-records': this.createdIds.size - 5,
      },
    };
    return stats;
  }
}

/**
 * Combined Level 3 Seed Suite
 */
export class Level3ExportSuite extends TestSeedFactory {
  async seed(): Promise<SeedResult> {
    this.context = this.createContext('e2e');
    const startTime = Date.now();

    try {
      if (this.hooks.beforeSeed) {
        await this.hooks.beforeSeed(this.context);
      }

      // 1. Create real-time exports
      const realTimeSeed = new OptimalRealTimeExportSeed(this.payload);
      const realtimeResult = await realTimeSeed.seed();
      if (!realtimeResult.success) throw realtimeResult.error;

      // 2. Create scheduled exports with history
      const scheduledSeed = new OptimalScheduledExportSeed(this.payload);
      const scheduledResult = await scheduledSeed.seed();
      if (!scheduledResult.success) throw scheduledResult.error;

      // 3. Create multi-destination configs
      const destinationSeed = new OptimalMultiDestinationSeed(this.payload);
      const destinationResult = await destinationSeed.seed();
      if (!destinationResult.success) throw destinationResult.error;

      // 4. Create error handling scenarios
      const errorSeed = new OptimalErrorHandlingSeed(this.payload);
      const errorResult = await errorSeed.seed();
      if (!errorResult.success) throw errorResult.error;

      // 5. Create compliance policies and audits
      const complianceSeed = new OptimalComplianceExportSeed(this.payload);
      const complianceResult = await complianceSeed.seed();
      if (!complianceResult.success) throw complianceResult.error;

      // Aggregate all created IDs
      this.aggregateCreatedIds([realTimeSeed, scheduledSeed, destinationSeed, errorSeed, complianceSeed]);

      if (this.hooks.afterSeed) {
        const stats = this.getStats();
        const result: SeedResult = {
          success: true,
          ...stats,
        };
        await this.hooks.afterSeed(this.context, result);
      }

      return {
        success: true,
        ...this.getStats(),
      };
    } catch (error) {
      return {
        success: false,
        seedLevel: 'e2e',
        totalTime: Date.now() - startTime,
        itemsCreated: 0,
        collections: {},
        error: error instanceof Error ? error : new Error(String(error)),
      };
    }
  }

  private aggregateCreatedIds(seeds: TestSeedFactory[]): void {
    seeds.forEach(seed => {
      const seedContext = (seed as any).context;
      if (seedContext && seedContext.createdIds) {
        for (const [collection, ids] of seedContext.createdIds) {
          if (!this.context!.createdIds.has(collection)) {
            this.context!.createdIds.set(collection, new Set());
          }
          for (const id of ids) {
            this.context!.createdIds.get(collection)!.add(id);
          }
        }
      }
    });
  }

  private getStats() {
    const stats: any = {
      seedLevel: 'e2e',
      totalTime: Date.now() - this.context!.startTime,
      itemsCreated: 0,
      collections: {},
    };

    for (const [collection, ids] of this.context!.createdIds) {
      stats.collections[collection] = ids.size;
      stats.itemsCreated += ids.size;
    }

    return stats;
  }
}
