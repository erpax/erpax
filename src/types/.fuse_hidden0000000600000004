/**
 * GL Account types — hierarchical chart of accounts per tenant, tied to
 * accounting standards.
 *
 * @standard ISO-4217:2015 currency-codes account-currency
 * @accounting IFRS IAS-1 presentation-of-financial-statements
 * @accounting US-GAAP ASC-105 generally-accepted-accounting-principles
 * @accounting US-GAAP ASC-210 balance-sheet
 * @accounting OECD SAF-T §2 general-ledger-accounts
 * @audit ISO-19011:2018 audit-trail
 * @see docs/STANDARDS.md §4.2
 */

export type AccountType =
  | 'asset'
  | 'liability'
  | 'equity'
  | 'revenue'
  | 'cogs'
  | 'expense'
  | 'other_income'
  | 'other_expense';

export type AccountStatus = 'active' | 'inactive' | 'locked';

export type AnalyticType =
  | 'none'
  | 'cost_center'
  | 'department'
  | 'location'
  | 'customer'
  | 'project';

/**
 * Core GL Account
 */
export interface GLAccount {
  id: string;
  hostId: string;
  code: string; // e.g., "1000", "1010", "1010.01"
  name: string;
  description?: string;
  type: AccountType;
  status: AccountStatus;

  // Hierarchy
  parentId?: string; // Reference to parent account
  level: number; // 0 = root, 1 = level 1 child, etc.
  isLeaf: boolean; // Can post transactions to this account?

  // Financial config
  normalBalance: 'debit' | 'credit'; // Natural balance direction
  currencyCode: string; // e.g., "USD", "EUR", multi-currency support
  allowMultiCurrency: boolean;

  // Analytics
  analyticType: AnalyticType;
  requiresAnalyticDimension: boolean;

  // Control
  allowPostings: boolean; // Can GL entries post to this?
  requiresApproval: boolean; // Must postings be approved?
  locked: boolean; // Prevent modification?

  // Tax
  isTaxable: boolean;
  taxCode?: string; // Reference to tax classification

  // Reporting
  displayOrder: number; // For statement layout
  isHeaderAccount: boolean; // Subtotal line on statements?

  // Audit
  createdAt: Date;
  updatedAt: Date;
  createdBy: string;
  updatedBy: string;
}

/**
 * Request types for CRUD
 */
export interface CreateGLAccountRequest {
  code: string;
  name: string;
  description?: string;
  type: AccountType;
  parentId?: string;
  normalBalance: 'debit' | 'credit';
  currencyCode: string;
  analyticType?: AnalyticType;
  requiresAnalyticDimension?: boolean;
  isTaxable?: boolean;
  taxCode?: string;
  displayOrder?: number;
}

export interface UpdateGLAccountRequest {
  name?: string;
  description?: string;
  status?: AccountStatus;
  normalBalance?: 'debit' | 'credit';
  analyticType?: AnalyticType;
  requiresAnalyticDimension?: boolean;
  allowPostings?: boolean;
  requiresApproval?: boolean;
  isTaxable?: boolean;
  taxCode?: string;
  displayOrder?: number;
}

/**
 * Account with hierarchy tree (for UI)
 */
export interface GLAccountNode extends GLAccount {
  children: GLAccountNode[];
  balance?: number; // Current balance
  parent?: GLAccountNode;
}

/**
 * GL Account Statistics
 */
export interface GLAccountStatistics {
  totalAccounts: number;
  activeAccounts: number;
  accountsByType: Record<AccountType, number>;
  accountsByStatus: Record<AccountStatus, number>;
  lastModified: Date;
}

/**
 * Account Scope Types (like Ruby ERPAX scopes)
 */
export type AccountScope =
  | 'all'
  | 'active'
  | 'inactive'
  | 'locked'
  | 'assets'
  | 'liabilities'
  | 'equity'
  | 'revenues'
  | 'expenses'
  | 'leaf_only'
  | 'with_analytics';

/**
 * Account Action Types (domain operations, not CRUD)
 */
export interface LockAccountAction {
  action: 'lock';
  accountIds: string[];
  reason?: string;
}

export interface UnlockAccountAction {
  action: 'unlock';
  accountIds: string[];
}

export interface MergeAccountAction {
  action: 'merge';
  sourceAccountId: string;
  targetAccountId: string;
  transferBalance: boolean;
}

export interface RebalanceAccountAction {
  action: 'rebalance';
  accountIds: string[];
  // Recalculate balances from journal entries
}

export type AccountAction =
  | LockAccountAction
  | UnlockAccountAction
  | MergeAccountAction
  | RebalanceAccountAction;

/**
 * GL Template for accounting standards
 * Maps standard chart structure to account hierarchy
 */
export interface GLTemplate {
  id: string;
  name: string; // e.g., "IFRS Chart", "GAAP Chart", "ASBE Chart"
  accountingStandard: string;
  description?: string;
  accounts: CreateGLAccountRequest[];
  isDefault: boolean;
}

