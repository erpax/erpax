# Copy to `.env.local` or run `pnpm run setup` after install (prompts for these values).

# Required for Payload (generate: openssl rand -hex 32)
PAYLOAD_SECRET=

# Optional: sealed PAYLOAD_SECRET at rest (JSON SealedBlob or path). Requires ERPAX_SEAL_KEY.
# PAYLOAD_SECRET_SEALED=
# ERPAX_SEAL_KEY=
# PAYLOAD_SECRET_IDENTITY_JSON=  # override default identity descriptor (see src/secret/SKILL.md)

# Wrangler environment name when using `wrangler deploy --env <name>` (optional)
CLOUDFLARE_ENV=

# Optional: canonical public URL. When unset, the app uses the incoming request Host
# (and optional tenant `publicSiteUrl` on Tenants) for links, OG URLs, and ecommerce client.
NEXT_PUBLIC_SERVER_URL=

# Root marketing site tenant slug (multi-tenant)
NEXT_PUBLIC_SITE_TENANT_SLUG=

# Resend: primary keys live on each Tenant (Tenants → Resend API key). These env vars are optional
# fallbacks for local development only.
RESEND_API_KEY=
EMAIL_DEFAULT_FROM_ADDRESS=
EMAIL_DEFAULT_FROM_NAME=

# Preview, cron job auth, etc. use secrets derived from PAYLOAD_SECRET (see src/utilities/deriveSecret.ts).

# Stripe: secret key, webhook signing secret, and publishable key should be set per Tenant in production.
# These env vars are optional fallbacks for local development (non-production only for publishable key).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Payload MCP (optional)
PAYLOAD_MCP_API_KEY=
PAYLOAD_MCP_URL=

# --- Cloudflare bindings live in `wrangler.jsonc` (D1, R2, ASSETS, IMAGES, services).
# Run `pnpm run setup` to set account_id, worker name, D1 database_id, R2 bucket, etc.
