{
  "name": "erpax",
  "version": "1.0.0",
  "description": "Open-source multi-tenant ERP & double-entry accounting on Payload CMS v4 + Cloudflare (D1 + R2 + Workers via OpenNext) — content-addressed, tamper-evident, standards-bound",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next dev",
    "dev:clean": "rm -rf .next .open-next && pnpm run dev",
    "build": "pnpm run skill:index && wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" payload generate:types && payload generate:importmap && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --webpack",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "preview": "opennextjs-cloudflare build --env=$CLOUDFLARE_ENV && opennextjs-cloudflare preview --env=$CLOUDFLARE_ENV",
    "deploy": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate && wrangler d1 execute D1 --command 'PRAGMA optimize' --env=$CLOUDFLARE_ENV --remote && opennextjs-cloudflare build --env=$CLOUDFLARE_ENV && opennextjs-cloudflare deploy --env=$CLOUDFLARE_ENV",
    "deploy:db": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate && wrangler d1 execute D1 --command 'PRAGMA optimize' --env=$CLOUDFLARE_ENV --remote",
    "deploy:app": "opennextjs-cloudflare build --env=$CLOUDFLARE_ENV && opennextjs-cloudflare deploy --env=$CLOUDFLARE_ENV",
    "payload": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" payload",
    "jobs:run": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" payload jobs:run --all-queues --limit 50",
    "lint": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" eslint .",
    "lint:src": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" eslint \"src/**/*.{ts,tsx}\" --ignore-pattern \"src/migrations/*_*.ts\" --max-warnings 0",
    "lint:fix": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "typecheck:all": "tsc --noEmit -p tsconfig.json",
    "standards": "bash scripts/standards-citation-index.sh --check && bash scripts/standards-citation-index.sh --required && cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" tsx scripts/standards-catalogue.ts --verify",
    "standards:catalogue": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" tsx scripts/standards-catalogue.ts",
    "translations": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" tsx src/translations/collect/index.ts --verify",
    "translations:collect": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" tsx src/translations/collect/index.ts",
    "spec:gen": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" tsx src/spec/gen.ts",
    "aura:scan": "node src/aura/scan.mjs",
    "lint:imports": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" node src/convention/import/gate.mjs",
    "lint:folders": "cross-env NODE_OPTIONS=\"--no-deprecation\" tsx src/law/folder/index.ts --check",
    "confirm": "node scripts/confirm.mjs",
    "confirm:full": "node scripts/confirm.mjs --full",
    "harmony": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" tsx src/harmony/scan.ts",
    "atoms:catalogue": "node src/atom/catalogue.mjs",
    "claude:plugin": "node scripts/claude-plugin.mjs",
    "matrix:generate": "node src/uuid/matrix/collide.mjs --emit",
    "skill:index": "node src/skill/router/build-index.mjs",
    "corpus:generate": "pnpm atoms:catalogue && pnpm matrix:generate && pnpm skill:index",
    "mint:atoms": "node src/generate/mint.mjs",
    "d1:audit": "node src/database/d1-column-audit.mjs",
    "db:regenerate": "bash scripts/db-regenerate.sh",
    "check": "pnpm run standards && bash scripts/payload-verify-types.sh && pnpm run lint && pnpm run lint:src && pnpm run lint:imports && pnpm run lint:folders && pnpm run typecheck && pnpm run test:int",
    "test": "pnpm run test:int",
    "test:int": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" vitest run --config ./vitest.config.mts",
    "test:int:fast": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" PAYLOAD_TEST_SKIP_MIGRATE=1 vitest run --config ./vitest.config.mts",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" SKIP_E2E_WEBSERVER=1 playwright test --config=playwright.config.ts",
    "test:e2e:erp": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" SKIP_E2E_WEBSERVER=1 playwright test --config=playwright.config.ts --project=erp-workflows-multimedia",
    "test:e2e:matrix": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" SKIP_E2E_WEBSERVER=1 playwright test --config=playwright.config.ts --project=erp-workflows-multimedia",
    "setup": "node scripts/setup-env.mjs",
    "prepare": "node scripts/setup-env.mjs --if-needed && husky",
    "seeds:coverage": "node src/spec/coverage.mjs",
    "import:blogger": "tsx src/services/ingest/blogger-to-json.ts",
    "import:blogger:payload": "tsx src/services/ingest/blogger-import.ts",
    "codemod": "bash scripts/payload-codemod.sh",
    "mcp:test": "node src/agents/mcp/tools-list.mjs",
    "docs:dev": "vitepress dev",
    "docs:build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=16000\" vitepress build",
    "docs:preview": "vitepress preview"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@payloadcms/admin-bar": "4.0.0-internal.38b7f1d",
    "@payloadcms/db-d1-sqlite": "4.0.0-internal.38b7f1d",
    "@payloadcms/email-resend": "4.0.0-internal.38b7f1d",
    "@payloadcms/live-preview-react": "4.0.0-internal.38b7f1d",
    "@payloadcms/next": "4.0.0-internal.38b7f1d",
    "@payloadcms/plugin-ecommerce": "4.0.0-internal.38b7f1d",
    "@payloadcms/plugin-form-builder": "4.0.0-internal.38b7f1d",
    "@payloadcms/plugin-import-export": "4.0.0-internal.38b7f1d",
    "@payloadcms/plugin-mcp": "4.0.0-internal.38b7f1d",
    "@payloadcms/plugin-multi-tenant": "4.0.0-internal.38b7f1d",
    "@payloadcms/plugin-nested-docs": "4.0.0-internal.38b7f1d",
    "@payloadcms/plugin-redirects": "4.0.0-internal.38b7f1d",
    "@payloadcms/plugin-search": "4.0.0-internal.38b7f1d",
    "@payloadcms/plugin-seo": "4.0.0-internal.38b7f1d",
    "@payloadcms/richtext-lexical": "4.0.0-internal.38b7f1d",
    "@payloadcms/sdk": "4.0.0-internal.38b7f1d",
    "@payloadcms/storage-r2": "4.0.0-internal.38b7f1d",
    "@payloadcms/translations": "4.0.0-internal.38b7f1d",
    "@payloadcms/ui": "4.0.0-internal.38b7f1d",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^0.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "geist": "^1.7.2",
    "graphql": "^16.14.1",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "next-intl": "^4.13.0",
    "next-sitemap": "^4.2.3",
    "payload": "4.0.0-internal.38b7f1d",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "recharts": "^2.15.4",
    "sharp": "^0.34.5",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "latest",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@cursor/sdk": "^1.0.18",
    "@payloadcms/eslint-plugin": "^3.28.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/escape-html": "^1.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "postcss": "latest",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "dompurify": "^3.4.2",
      "uuid": "^14.0.0",
      "esbuild": "^0.28.0",
      "ip-address": "^10.2.0",
      "@eslint/plugin-kit": "^0.7.1",
      "postcss": "^8.5.14"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "sqlite3",
      "unrs-resolver",
      "workerd"
    ]
  },
  "cloudflare": {
    "bindings": {
      "PAYLOAD_SECRET": {
        "description": "Generate a random string using `openssl rand -hex 32`"
      }
    }
  }
}
