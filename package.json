{
  "name": "erpax",
  "version": "1.0.0",
  "description": "Payload website on Cloudflare (D1 + R2 + OpenNext)",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --webpack",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "build:workers": "pnpm run migrate:production && pnpm run build",
    "deploy": "pnpm run deploy:database && pnpm run deploy:app",
    "deploy:app": "opennextjs-cloudflare build --env=$CLOUDFLARE_ENV && opennextjs-cloudflare deploy --env=$CLOUDFLARE_ENV",
    "deploy:database": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate && wrangler d1 execute D1 --command 'PRAGMA optimize' --env=$CLOUDFLARE_ENV --remote",
    "migrate:production": "cross-env NODE_ENV=production payload migrate",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && rm -rf .open-next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "pnpm run generate:types:cloudflare && pnpm run generate:types:payload",
    "generate:types:cloudflare": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "generate:types:payload": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload:verify-types": "bash scripts/payload-verify-types.sh",
    "jobs:run": "cross-env NODE_OPTIONS=--no-deprecation payload jobs:run --all-queues --limit 50",
    "setup": "node scripts/setup-env.mjs",
    "prepare": "node scripts/setup-env.mjs --if-needed && husky",
    "ii": "pnpm install --ignore-workspace",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:src": "cross-env NODE_OPTIONS=--no-deprecation eslint \"src/**/*.{ts,tsx}\" --ignore-pattern \"src/migrations/*_*.ts\" --max-warnings 0",
    "lint:payload-app": "pnpm run lint:src",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "typecheck:all": "tsc --noEmit -p tsconfig.json",
    "standards:audit": "bash scripts/standards-citation-index.sh",
    "standards:counts": "bash scripts/standards-citation-index.sh --counts",
    "standards:check": "bash scripts/standards-citation-index.sh --check",
    "standards:required": "bash scripts/standards-citation-index.sh --required",
    "standards:write-index": "bash scripts/standards-citation-index.sh --write-index",
    "standards:verify-index": "bash scripts/standards-citation-index.sh --verify-index",
    "check": "pnpm run standards:check && pnpm run standards:required && pnpm run standards:verify-index && pnpm run payload:verify-types && pnpm run lint && pnpm run lint:src && pnpm run typecheck && pnpm run test:int",
    "import:blogger": "tsx scripts/blogger-atom-to-posts-json.ts",
    "import:blogger:payload": "tsx scripts/import-blogger-to-payload.ts",
    "mcp:test": "node scripts/mcp-tools-list.mjs",
    "codemod": "bash scripts/payload-codemod.sh",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview --env=$CLOUDFLARE_ENV",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" SKIP_E2E_WEBSERVER=1 playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation PAYLOAD_TEST_SKIP_MIGRATE=1 vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.6",
    "@payloadcms/admin-bar": "^3.84.1",
    "@payloadcms/db-d1-sqlite": "^3.84.1",
    "@payloadcms/email-resend": "^3.84.1",
    "@payloadcms/live-preview-react": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/plugin-ecommerce": "^3.84.1",
    "@payloadcms/plugin-form-builder": "^3.84.1",
    "@payloadcms/plugin-import-export": "^3.84.1",
    "@payloadcms/plugin-mcp": "^3.84.1",
    "@payloadcms/plugin-multi-tenant": "^3.84.1",
    "@payloadcms/plugin-nested-docs": "^3.84.1",
    "@payloadcms/plugin-redirects": "^3.84.1",
    "@payloadcms/plugin-search": "^3.84.1",
    "@payloadcms/plugin-seo": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/sdk": "^3.84.1",
    "@payloadcms/storage-r2": "^3.84.1",
    "@payloadcms/translations": "^3.84.1",
    "@payloadcms/ui": "^3.84.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "geist": "^1.7.0",
    "graphql": "^16.14.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "next-intl": "^4.11.0",
    "next-sitemap": "^4.2.3",
    "payload": "^3.84.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "sharp": "^0.34.5",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@cursor/sdk": "^1.0.12",
    "@payloadcms/eslint-plugin": "^3.28.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/escape-html": "^1.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.88.0"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "dompurify": "^3.4.2",
      "uuid": "^14.0.0",
      "esbuild": "^0.28.0",
      "ip-address": "^10.2.0",
      "@eslint/plugin-kit": "^0.7.1",
      "postcss": "^8.5.14"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "sqlite3",
      "unrs-resolver",
      "workerd"
    ]
  },
  "cloudflare": {
    "bindings": {
      "PAYLOAD_SECRET": {
        "description": "Generate a random string using `openssl rand -hex 32`"
      }
    }
  }
}
